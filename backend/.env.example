# =============================================================================
# NUNCA commitar este arquivo com valores reais.
# Copie para .env e preencha com suas credenciais.
# Em produção, prefira Secret Manager ou variáveis de ambiente do Docker.
# =============================================================================

# Horizon Stellar (testnet ou mainnet)
HORIZON_URL=https://horizon-testnet.stellar.org

# Rede Stellar: "testnet" ou "public"
STELLAR_NETWORK=testnet

# Conta Stellar da empresa (criada via POST /api/wallet)
COMPANY_ACCOUNT=G...
# Chave privada: NUNCA expor. Em produção prefira Secret Manager.
COMPANY_SECRET=S...

# Porta do servidor
PORT=3000
NODE_ENV=production

# Chave admin para rotas protegidas (POST /api/blockchain, GET /api/admin/*)
ADMIN_API_KEY=

# URL pública do Guardian (usada nas respostas de onboarding do Asaas)
GUARDIAN_PUBLIC_URL=https://www.boletoguardian.xyz

# Multi-tenant Asaas: array JSON (ver integrations/asaas/config/tenants.example.json)
# TENANTS_JSON=[{"tenantId":"loja_a","asaasEnv":"sandbox",...}]

# Overrides por tenant (opcional — sobrescreve os valores do TENANTS_JSON)
# TENANT_LOJA_A_ASAAS_API_KEY=
# TENANT_LOJA_A_WEBHOOK_TOKEN=
# TENANT_LOJA_A_COMPANY_ACCOUNT=
# TENANT_LOJA_A_COMPANY_SECRET=
# TENANT_LOJA_A_ASAAS_ENV=sandbox
