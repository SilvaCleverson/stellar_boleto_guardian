# =============================================================================
# NUNCA enviar no deploy: senhas, tokens, chaves privadas, hashes de assinatura.
# Use variaveis de ambiente no servidor ou Secret Manager; nunca commite .env
# com valores reais. Este arquivo e apenas modelo (env.example).
# =============================================================================

# Horizon Stellar (testnet ou mainnet)
HORIZON_URL=https://horizon-testnet.stellar.org

# Rede Stellar: "testnet" ou "public"
STELLAR_NETWORK=testnet

# Conta Stellar da empresa (criada via POST /api/wallet ou node createCompanyAccount.js)
COMPANY_ACCOUNT=G...
# Chave privada: NUNCA commitar nem expor. Em producao prefira Secret Manager.
COMPANY_SECRET=S...

# Servidor
PORT=3000
NODE_ENV=development

# Producao: usar HTTPS (reverse proxy/load balancer). Restringir acesso ao .env (apenas processo da API).
