# =============================================================================
# NUNCA enviar no deploy: senhas, tokens, chaves privadas, hashes de assinatura.
# Use variaveis de ambiente no servidor ou Secret Manager; nunca commite .env
# com valores reais. Este arquivo e apenas modelo (env.example).
# =============================================================================

# Horizon Stellar (testnet ou mainnet)
HORIZON_URL=https://horizon-testnet.stellar.org

# Rede Stellar: "testnet" ou "public"
STELLAR_NETWORK=testnet

# Conta Stellar da empresa (criada via POST /api/wallet ou node createCompanyAccount.js)
COMPANY_ACCOUNT=G...
# Chave privada: NUNCA commitar nem expor. Em producao prefira Secret Manager.
COMPANY_SECRET=S...

# Servidor
PORT=3000
NODE_ENV=development

# Producao: usar HTTPS (reverse proxy/load balancer). Restringir acesso ao .env (apenas processo da API).

# Chave admin para POST /api/blockchain e gestao de tenants Asaas
ADMIN_API_KEY=

# URL publica do Guardian (usada em respostas de onboarding Asaas)
GUARDIAN_PUBLIC_URL=https://www.boletoguardian.xyz

# Multi-tenant Asaas: array JSON (ver Integracao/ASAAS/config/tenants.example.json)
# TENANTS_JSON=[{"tenantId":"loja_a","asaasEnv":"sandbox",...}]

# Overrides por tenant (opcional, preferivel para secrets no Vercel)
# TENANT_LOJA_A_ASAAS_API_KEY=
# TENANT_LOJA_A_WEBHOOK_TOKEN=
# TENANT_LOJA_A_COMPANY_ACCOUNT=
# TENANT_LOJA_A_COMPANY_SECRET=
# TENANT_LOJA_A_ASAAS_ENV=sandbox
